n1 = int(input()) # 처음 입력 값 예)26
n2 = n1
many = 0
while True:
    new= ((n2 // 10) + (n2 % 10)) % 10 # 십의 자리 2 + 일의 자리 6 = 새로운 수 8
    n2 = (n2 % 10) * 10 + new  # 십의 자리 수 6 * 10 + 새로운 수 8 = n2는 26에서 68이 됨
    many = many + 1 # 한 번 싸이클이 돌면 한 번으로 센다
    if (n1 == n2): break # 싸이클을 돌고 바뀐 n2의 값이 초기 n2인 n1과 같아지면 끝
print(many)
